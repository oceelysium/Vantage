# Oracle's Elixir CSV URL, for the networked pro builder (pro-index).
# The local builder (pro:local) reads a file path argument instead.
OE_CSV_URL=

# Base URL to fetch the soloqueue prior from (pro:local / pro:backtest).
# Leave blank to fall back to the upstream DraftGap bucket.
DATASET_BASE_URL=

# Pro dataset build tuning (optional)
PRO_PRIOR_GAMES=100
# PRO_PATCH=16.10
# PRO_LEAGUE=LCK,LPL

# S3-compatible storage — only needed if you publish datasets to your own bucket.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
