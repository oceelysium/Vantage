# Base URL serving the soloqueue datasets (expects datasets/v5/*.json).
# Leave blank to fall back to the upstream DraftGap bucket (fine for local use).
# Point this at your own host before deploying anything public.
VITE_DATASET_BASE_URL=

# Full URL of the pro dataset, if hosting it on a bucket instead of bundling it
# into the site. Leave blank to serve /datasets/pro-current-patch.json locally.
VITE_PRO_DATASET_URL=

# Google Analytics tag (e.g. G-XXXXXXXXXX). Leave blank to disable analytics.
VITE_GA_TAG=
